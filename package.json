{
  "name": "golf-charity-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Golf Charity Subscription Platform — Monorepo",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
  "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
  "build": "npm run build --workspace=client",
  "vercel-build": "npm install --prefix client && npm run build --prefix client"
},
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}