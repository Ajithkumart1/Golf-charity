# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Supabase ────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — NEVER expose in browser. Used for admin/DB operations.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon key — REQUIRED for login (signInWithPassword needs anon key, not service role)
SUPABASE_ANON_KEY=eyJ...

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=minimum-32-character-random-secret-here
JWT_EXPIRES_IN=7d

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# ── Storage ─────────────────────────────────────────────────────────────────
SUPABASE_PROOF_BUCKET=proof-uploads
