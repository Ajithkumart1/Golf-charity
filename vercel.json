{
  "version": 2,
  "buildCommand": "npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install && npm install --prefix server",
  "functions": {
    "server/src/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/src/index.js" },
    { "source": "/(.*)",     "destination": "/client/dist/index.html" }
  ]
}