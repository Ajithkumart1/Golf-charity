# ── Client Environment Variables ────────────────────────────────────────────
# Copy this file to client/.env and fill in your values.

# Supabase — get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Stripe publishable key (safe to expose in browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# API URL:
#   Development: leave COMMENTED OUT — Vite proxy handles /api/* → localhost:3001
#   Production:  set to your Vercel domain (no trailing slash, no /api suffix)
# VITE_API_URL=https://your-app.vercel.app
